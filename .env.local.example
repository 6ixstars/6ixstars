# =====================================================
# 6ixstars — Variables de entorno
# Copia este archivo a .env.local y completa los valores.
# =====================================================

# -----------------------------------------------------
# SUPABASE — Catálogo y órdenes (proyecto NUEVO de 6ixstars)
# -----------------------------------------------------
# Obtén estos valores en: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
# Service role: SOLO server-side. NUNCA commitear ni exponer al frontend.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# -----------------------------------------------------
# WOMPI — Pasarela de pago (Bancolombia / Colombia)
# -----------------------------------------------------
# Llaves en: https://comercios.wompi.co/  →  Configuración → API
# TEST: pub_test_xxx  ·  PROD: pub_prod_xxx
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_TU_LLAVE_AQUI
WOMPI_INTEGRITY_SECRET=tu_integrity_secret_aqui
WOMPI_EVENTS_SECRET=tu_events_secret_aqui

# -----------------------------------------------------
# SITIO
# -----------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tasa USD → COP (si tus precios ya están en COP, pon 1)
NEXT_PUBLIC_USD_TO_COP_RATE=1

# =====================================================
# Tarjetas de prueba Wompi (sandbox):
#   Aprobada: 4242 4242 4242 4242 · Rechazada: 4111 1111 1111 1111
#   CVV: 3 dígitos · Vence: fecha futura
# Webhook (post-deploy): https://tu-dominio.com/api/wompi/webhook
# =====================================================
